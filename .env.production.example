# =============================================================================
# FLUX - Variables de entorno para PRODUCCIÓN
# =============================================================================
# Copiar este archivo a .env.production y completar los valores.
# NUNCA commitear .env.production al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# AUTO-UPDATER (opcional)
# Si no está definida, el auto-updater queda deshabilitado (no-op).
# Valor: URL del feed de updates publicado con electron-builder.
#   - GitHub Releases: https://github.com/<org>/<repo>/releases/latest/download
#   - S3: https://s3.amazonaws.com/<bucket>/latest.yml
# -----------------------------------------------------------------------------
UPDATE_FEED_URL=

# -----------------------------------------------------------------------------
# STREAMING — Icecast (opcional, configurable también desde la UI)
# Estas variables son fallback si la UI no tiene configuración guardada.
# Los valores ingresados desde la UI se persisten en la base de datos local.
# -----------------------------------------------------------------------------
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_MOUNT=/stream
ICECAST_USERNAME=source
ICECAST_PASSWORD=hackme
ICECAST_BITRATE=128

# -----------------------------------------------------------------------------
# STREAMING — Shoutcast (opcional, configurable también desde la UI)
# -----------------------------------------------------------------------------
SHOUTCAST_HOST=localhost
SHOUTCAST_PORT=8000
SHOUTCAST_PASSWORD=hackme
SHOUTCAST_MOUNT=/stream

# -----------------------------------------------------------------------------
# BASE DE DATOS (normalmente no requiere cambios)
# La DB se ubica en userData/flux.db (gestionado por Electron internamente).
# Solo modificar si se usa una ruta custom de SQLite fuera del userData.
# -----------------------------------------------------------------------------
# DATABASE_URL=file:/path/custom/flux.db

# -----------------------------------------------------------------------------
# LOGGING
# Nivel de log: error | warn | info | verbose | debug | silly
# Por defecto: info en producción.
# -----------------------------------------------------------------------------
LOG_LEVEL=info
